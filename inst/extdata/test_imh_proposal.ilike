double proposal_mean = 1.0;
double proposal_sd = 1.0;

/***simulate_imh_proposal***/
Parameters simulate_imh_proposal(RandomNumberGenerator &rng) {
  arma::colvec theta(1, 1);
  theta[0] = rnorm(rng, proposal_mean, proposal_sd);
  return Parameters("theta", theta);
}

/***evaluate_log_imh_proposal***/
double log_evaluate_imh_proposal(const Parameters &params) {
  double theta = params["theta"][0];
  return dnorm(theta, proposal_mean, proposal_sd);
}

/***mcmc_termination,ilike::iterations(10000)***/
